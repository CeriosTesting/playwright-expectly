{
	"name": "@cerios/playwright-expectly",
	"version": "1.3.4",
	"description": "Comprehensive Playwright test matchers for strings, numbers, dates, arrays, objects, and locators. Simplify your E2E tests with intuitive assertions like toBeAlphanumeric, toHaveAscendingOrder, toBeInTheFuture, and 50+ more matchers.",
	"keywords": [
		"array-validation",
		"assertions",
		"cerios",
		"date-validation",
		"e2e",
		"end-to-end",
		"expect",
		"locator",
		"matchers",
		"playwright",
		"qa",
		"string-validation",
		"test",
		"test-automation",
		"testing",
		"typescript",
		"validation"
	],
	"homepage": "https://github.com/CeriosTesting/playwright-expectly#readme",
	"bugs": {
		"url": "https://github.com/CeriosTesting/playwright-expectly/issues"
	},
	"license": "MIT",
	"author": "Ronald Veth - Cerios",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CeriosTesting/playwright-expectly.git",
		"directory": "packages/playwright-expectly"
	},
	"files": [
		"dist"
	],
	"type": "commonjs",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "tsdown",
		"changeset": "changeset",
		"check-exports": "attw --pack .",
		"check": "npm run lint && npm run format:check",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware --type-check",
		"lint:fix": "oxlint --type-aware --type-check --fix",
		"prepare": "husky",
		"test": "playwright test",
		"update-all-packages": "npx npm-check-updates -u && npm i",
		"version-packages": "changeset version",
		"version-packages:prepare-release": "npm run version-packages && npm run format",
		"release": "changeset publish --provenance"
	},
	"dependencies": {
		"@cerios/playwright-expectly-core": "*"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.4",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.61.1",
		"@types/node": "^26.0.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"npm-check-updates": "^22.2.9",
		"oxfmt": "^0.57.0",
		"oxlint": "^1.72.0",
		"oxlint-tsgolint": "^0.23.0",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@playwright/test": ">=1.40.0"
	}
}

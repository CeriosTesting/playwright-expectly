{
	"name": "playwright-expectly-workspace",
	"private": true,
	"workspaces": [
		"packages/playwright-expectly-core",
		"packages/playwright-expectly",
		"packages/playwright-expectly-fuzzy"
	],
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"changeset": "changeset",
		"check-exports": "npm run check-exports --workspaces --if-present",
		"check": "npm run lint && npm run format:check",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware --type-check",
		"lint:fix": "oxlint --type-aware --type-check --fix",
		"prepare": "husky",
		"test": "npm run test --workspaces --if-present",
		"update-all-packages": "npx npm-check-updates -u && npm i",
		"version-packages": "changeset version",
		"version-packages:prepare-release": "npm run version-packages && npm run format",
		"release": "changeset publish --provenance"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.60.0",
		"@types/node": "^25.9.3",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"npm-check-updates": "^22.2.3",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"oxlint-tsgolint": "^0.23.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	}
}

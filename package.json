{
	"name": "playwright-expectly-workspace",
	"private": true,
	"workspaces": [
		"packages/playwright-expectly-core",
		"packages/playwright-expectly",
		"packages/playwright-expectly-fuzzy"
	],
	"scripts": {
		"build": "npm run --workspaces build",
		"changeset": "changeset",
		"deps:check": "syncpack lint",
		"deps:fix": "syncpack fix",
		"deps:update": "npx npm-check-updates --workspaces -u --dep prod,dev,optional,peer,packageManager --install never && npm install --workspaces",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware --type-check",
		"lint:fix": "oxlint --type-aware --type-check --fix",
		"pack": "npm pack --workspaces",
		"prepare": "husky",
		"release": "changeset publish",
		"test": "playwright test --config=./playwright.config.ts",
		"test:integration": "playwright test --config=./playwright.config.ts --project=integration",
		"report:show": "npx playwright show-report",
		"version-packages": "changeset version",
		"version-packages:prepare-release": "npm run version-packages && npm run format"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.4",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.61.1",
		"@types/node": "^26.1.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"npm-check-updates": "^22.2.9",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"syncpack": "^15.3.2",
		"tsdown": "^0.22.3",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": "^22.18.0 || >=24.11.0"
	}
}

{
	"name": "playwright-expectly-workspace",
	"private": true,
	"workspaces": [
		"packages/playwright-expectly-core",
		"packages/playwright-expectly",
		"packages/playwright-expectly-fuzzy"
	],
	"scripts": {
		"build": "npm run --workspaces build",
		"changeset": "changeset",
		"deps:check": "syncpack lint",
		"deps:fix": "syncpack fix",
		"deps:update": "npx npm-check-updates --workspaces -u --dep prod,dev,optional,peer,packageManager --install never && npm install --workspaces",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "oxlint --type-aware",
		"lint:fix": "oxlint --type-aware --fix",
		"pack": "npm run --workspaces pack",
		"prepare": "husky",
		"release": "changeset publish",
		"test": "npm run --workspaces test",
		"version-packages": "changeset version",
		"version-packages:prepare-release": "npm run version-packages && npm run format"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@changesets/cli": "^2.31.0",
		"@playwright/test": "^1.60.0",
		"@types/node": "^25.9.3",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"npm-check-updates": "^22.2.3",
		"oxfmt": "^0.54.0",
		"oxlint": "^1.69.0",
		"oxlint-tsgolint": "^0.23.0",
		"syncpack": "^15.3.1",
		"tsdown": "^0.22.2",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=20.19.0"
	}
}
